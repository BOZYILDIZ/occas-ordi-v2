# ─── Base de données PostgreSQL ────────────────────────────────────────────────
# Utilise Neon (https://neon.tech) pour Vercel — copie l'URL de connexion "Pooled"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# URL directe (pour les migrations Prisma — sans pgBouncer)
# Sur Neon : utilise l'URL non-poolée
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── NextAuth v5 ───────────────────────────────────────────────────────────────
# Génère un secret fort : openssl rand -base64 32
AUTH_SECRET="remplace-par-un-secret-aleatoire-de-32-chars"

# URL de base de ton app (Vercel la détecte automatiquement, mais garde-la pour dev)
NEXTAUTH_URL="https://ton-projet.vercel.app"

# ─── URL publique de l'app ─────────────────────────────────────────────────────
# Utilisée pour les QR codes sur les étiquettes
NEXT_PUBLIC_APP_URL="https://ton-projet.vercel.app"

# ─── Google Custom Search (optionnel) ─────────────────────────────────────────
GOOGLE_API_KEY=""
GOOGLE_CSE_ID=""

# ─── MFA ───────────────────────────────────────────────────────────────────────
MFA_ISSUER="OccasOrdi"
